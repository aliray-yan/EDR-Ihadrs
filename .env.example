# IHADRS local API
# IHADRS_API_TOKEN=change-me

# SecureOps SOC export
IHADRS_SECUREOPS_ENABLED=false
IHADRS_SECUREOPS_API_BASE_URL=http://127.0.0.1:8000/api/v1
IHADRS_SECUREOPS_ALLOW_HTTP_LAB=true
IHADRS_SECUREOPS_QUEUE_DB_PATH=./data/secureops_queue.db

# Prefer saving the ingest key from the web dashboard so it is protected
# with Windows DPAPI. This env var is useful for temporary lab runs only
# and should not be committed or logged.
# IHADRS_SECUREOPS_INGEST_KEY=
